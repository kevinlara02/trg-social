# ====================================
# PRODUCTION ENVIRONMENT VARIABLES
# ====================================

# SUPABASE (Database & Auth)
# Get from: https://app.supabase.com → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# GOOGLE BUSINESS PROFILE (Reviews)
# Get from: https://console.cloud.google.com
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
GOOGLE_CLOUD_PROJECT_ID=your-project-id

# GOOGLE ANALYTICS (Traffic Data)
GOOGLE_ANALYTICS_PROPERTY_ID=123456789
GOOGLE_ANALYTICS_SERVICE_ACCOUNT={"type":"service_account",...}

# META (Facebook & Instagram)
# Get from: https://developers.facebook.com
VITE_META_APP_ID=your-meta-app-id
VITE_META_APP_SECRET=your-meta-app-secret
META_PAGE_ACCESS_TOKEN_TB=your-token-the-benediction
META_PAGE_ACCESS_TOKEN_TW=your-token-toast-whittier
META_PAGE_ACCESS_TOKEN_SW=your-token-story-whittier
META_PAGE_ACCESS_TOKEN_SA=your-token-story-anaheim
META_PAGE_ACCESS_TOKEN_SB=your-token-story-brea
META_PAGE_ACCESS_TOKEN_BM=your-token-benny-marys
META_PAGE_ACCESS_TOKEN_TD=your-token-toast-downey
VITE_INSTAGRAM_BUSINESS_ACCOUNT_IDS=id1,id2,id3,id4,id5,id6,id7

# YELP (Reviews - Read Only)
# Get from: https://www.yelp.com/developers
VITE_YELP_API_KEY=your-yelp-api-key
YELP_BUSINESS_ID_TB=your-business-id
YELP_BUSINESS_ID_TW=your-business-id
YELP_BUSINESS_ID_SW=your-business-id
YELP_BUSINESS_ID_SA=your-business-id
YELP_BUSINESS_ID_SB=your-business-id
YELP_BUSINESS_ID_BM=your-business-id
YELP_BUSINESS_ID_TD=your-business-id

# ANTHROPIC (Claude AI for Replies)
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=your-claude-api-key

# SQUARESPACE (Contact Forms - Optional)
VITE_SQUARESPACE_API_KEY=your-squarespace-key
SQUARESPACE_SITE_ID=your-site-id
SQUARESPACE_COLLECTION_IDS=id1,id2,id3

# OPENTABLE & TRIPADVISOR (Optional)
OPENTABLE_API_KEY=your-opentable-key
TRIPADVISOR_API_KEY=your-tripadvisor-key

# APP CONFIG
VITE_APP_NAME=Digital Monitor
