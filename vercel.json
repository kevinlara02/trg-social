{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/meta-posts", "destination": "/api/meta?fn=posts" },
    { "source": "/api/meta-comments", "destination": "/api/meta?fn=comments" },
    { "source": "/api/meta-dms", "destination": "/api/meta?fn=dms" },
    { "source": "/api/meta-live", "destination": "/api/meta?fn=live" },
    { "source": "/api/meta-publish", "destination": "/api/meta?fn=publish" },
    { "source": "/api/meta-comment-reply", "destination": "/api/meta?fn=comment-reply" },
    { "source": "/api/meta-dm-reply", "destination": "/api/meta?fn=dm-reply" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ],
  "crons": [{ "path": "/api/snapshot", "schedule": "0 8 * * *" }]
}
